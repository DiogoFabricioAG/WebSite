---
import { Image } from 'astro:assets';

interface TechIcon {
  name: string;
  icon: string;
}

interface Metric {
  label: string;
  value: string;
}

interface Props {
  id: string;
  title: string;
  description: string;
  finishDate: string;
  status?: 'done' | 'wip' | 'paused' | 'mvp';
  icon?: string | null;
  liveUrl?: string | null;
  repoUrl?: string | null;
  demoUrl?: string | null; 
  imagesUrl?: string | null; 
  features?: string[];
  metrics?: Metric[];
  tags?: string[];
  techs?: TechIcon[];
  images?: string[];
  problem?: string;
  solution?: string;
  impact?: string;
  role?: string;
  architecture?: string[];
}

const {
  id,
  title,
  description,
  finishDate,
  status,
  icon,
  techs = [],
  liveUrl,
  repoUrl,
  demoUrl,
  imagesUrl,
  features = [],
  metrics = [],
  tags = [],
  images = [],
  problem,
  solution,
  impact,
  role,
  architecture = [],
} = Astro.props as Props;
---

<div class="relative flex flex-col w-full mx-auto group">

  {/* MAIN CONTENT BLOCK */}
  <article class="w-full bg-black/50 border border-white/12 p-8 md:p-12 flex flex-col relative transition-all duration-300 group-hover:shadow-[2px_2px_15px] group-hover:shadow-premium/50 grayscale group-hover:grayscale-0">
    
    {/* TAB DE FECHA */}
    <div class="absolute -top-[28px] left-[-1px] bg-white text-black border border-white px-4 py-1 font-bold text-[10px] md:text-xs uppercase tracking-widest z-20">
      {finishDate === 'ACT' ? 'En Desarrollo' : finishDate} {role && ` | ${role}`}
    </div>

    {/* TECHS (Flotando arriba, alineados a la derecha) */}
    <div class="absolute -top-[20px] right-4 md:right-8 flex flex-wrap justify-end gap-2 z-20 max-w-[50%]">
      {techs.map((tech, index) => (
        <div 
          class={`size-10 bg-black border flex items-center justify-center p-2 transition-transform hover:-translate-y-1 ${index === 0 ? 'border-premium shadow-[0_0_10px_rgba(186,154,116,0.3)]' : 'border-white/20'}`}
          title={tech.name}
        >
          <Image src={tech.icon.startsWith('/') ? tech.icon : `/${tech.icon}`} alt={tech.name} width={40} height={40} class="w-full h-full object-contain" />
        </div>
      ))}
    </div>

    {/* Título y Tags */}
    <div>
      <h3 class="text-3xl md:text-5xl font-bold text-white mb-3 mt-4 tracking-wide">{title}</h3>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-6">
          {tags.map(tag => (
            <span class="text-[9px] uppercase tracking-widest border border-white/20 px-2 py-0.5 text-white/60 bg-white/5">{tag}</span>
          ))}
        </div>
      )}
    </div>

    {/* Contenido a dos columnas para aprovechar el espacio */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-2 w-full">
      
      {/* Columna Izquierda: Contexto */}
      <div class="space-y-5">
        <div>
          <h4 class="text-xs uppercase tracking-widest text-premium mb-1">Descripción</h4>
          <p class="text-xs md:text-sm font-light text-white/80 leading-relaxed relative z-10">
            {description}
          </p>
        </div>

        {problem && (
          <div>
             <h4 class="text-xs uppercase tracking-widest text-white/50 mb-1">El Problema</h4>
             <p class="text-[11px] font-light text-white/70 leading-relaxed">
               {problem}
             </p>
          </div>
        )}

        {solution && (
          <div>
             <h4 class="text-xs uppercase tracking-widest text-white/50 mb-1">La Solución</h4>
             <p class="text-[11px] font-light text-white/70 leading-relaxed">
               {solution}
             </p>
          </div>
        )}
      </div>

      {/* Columna Derecha: Detalles Técnicos y Logros */}
      <div class="space-y-6">
        
        {/* METRICS */}
        {metrics.length > 0 && (
          <div>
            <h4 class="text-xs uppercase tracking-widest text-premium mb-2">Impacto / Métricas</h4>
            <div class="grid grid-cols-2 gap-3">
              {metrics.map((m) => (
                <div class="flex flex-col bg-white/5 p-2 border border-white/10">
                  <span class="text-white font-bold text-lg leading-none">{m.value}</span>
                  <span class="text-[9px] uppercase tracking-wider text-white/50 mt-1">{m.label}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* FEATURES */}
        <div class="space-y-4">
          {features.length > 0 && (
            <div>
              <h4 class="text-xs uppercase tracking-widest text-white/50 mb-2">Características Clave</h4>
              <ul class="space-y-1.5 text-[11px] leading-snug">
                {features.slice(0, 4).map((f) => (
                  <li class="flex items-start gap-1.5">
                    <span class="text-premium text-[10px] leading-none mt-0.5">✦</span>
                    <span class="text-white/80 font-light">{f}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>

      {/* BLOQUE INFERIOR: ARQUITECTURA (Ocupa ambas columnas) */}
      {architecture.length > 0 && (
        <div class="md:col-span-2 pt-4 border-t border-white/10 mt-2">
          <h4 class="text-xs uppercase tracking-widest text-white/50 mb-3">Arquitectura Técnica</h4>
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-2 text-[11px] leading-snug">
            {architecture.map((a) => (
              <li class="flex items-start gap-2">
                <span class="text-white/40 text-[10px] leading-none mt-0.5">▹</span>
                <span class="text-white/70 font-light">{a}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

    </div>
  </article>

  {/* BOTTOM ACTIONS BAR */}
  <div class="w-full flex flex-row justify-between items-center mt-4 grayscale group-hover:grayscale-0 transition-all duration-300">
    
    {/* Logo del proyecto (Izquierda) */}
    <div>
      <div class="size-14 border border-white/20 flex items-center justify-center p-2 hover:border-premium transition-colors">
        {icon ? (
          <Image src={icon.startsWith('/') ? icon : `/${icon}`} alt={`${title} logo`} width={56} height={56} class="w-full h-full object-contain" />
        ) : (
          <span class="text-white font-bold text-xs text-center leading-none">PRJ<br/>APP</span>
        )}
      </div>
    </div>

    {/* Botones de acción (Rombos con SVG) a la derecha */}
    <div class="flex flex-row gap-4 md:gap-6 items-center justify-end">
      
      {liveUrl && (
        <a href={liveUrl} target="_blank" rel="noopener noreferrer" class="size-12 border border-white/20 flex items-center justify-center hover:bg-white/10 hover:border-premium transition-all rotate-45 group/btn" title="Live Website">
           <span class="-rotate-45 text-white group-hover/btn:text-premium transition-colors">
             <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
               <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
             </svg>
           </span>
        </a>
      )}

      {repoUrl && (
        <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="size-12 border border-white/20 flex items-center justify-center hover:bg-white/10 hover:border-premium transition-all rotate-45 group/btn" title="Repositorio GitHub">
           <span class="-rotate-45 text-white group-hover/btn:text-premium transition-colors">
             <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
               <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
               <path d="M9 18c-4.51 2-5-2-7-2"></path>
             </svg>
           </span>
        </a>
      )}

      {(demoUrl || imagesUrl) && (
        <a href={demoUrl || imagesUrl} target="_blank" rel="noopener noreferrer" class="size-12 border border-white/20 flex items-center justify-center hover:bg-white/10 hover:border-premium transition-all rotate-45 group/btn" title="Ver Demo/Video">
           <span class="-rotate-45 text-white group-hover/btn:text-premium transition-colors">
             <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
               <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
             </svg>
           </span>
        </a>
      )}
    </div>
  </div>
</div>