---
---

<section id="inicio" class="min-h-screen justify-center w-3/4 mx-auto gap-6 sm:gap-10 px-4 items-center flex flex-col sm:flex-row">
  <div class="relative">
    <img 
      id="avatar-bw"
      src="/avatar-26.png" 
      alt="Avatar" 
      class="w-40 sm:w-48 md:w-80 lg:w-96 shadow-md [mask-image:radial-gradient(ellipse_at_center,black_45%,transparent_75%)] object-cover animate-blur-pulse cursor-pointer"
    >
    <img 
      id="avatar-color"
      src="/avatar-26-color.png" 
      alt="Avatar Color" 
      class="absolute top-0 left-0 w-40 sm:w-48 md:w-80 lg:w-96 shadow-md [mask-image:radial-gradient(ellipse_at_center,black_45%,transparent_75%)] object-cover animate-blur-pulse cursor-pointer opacity-0 transition-opacity duration-500"
    >
  </div>
  <div class="space-y-5 text-center sm:text-end flex-1">
    <h2 class="text-2xl sm:text-4xl md:text-6xl lg:text-9xl font-extrabold">
      Diogo Abregu 
    </h2>
    <p class="text-xs sm:text-xl font-light text-white">
      <span class="font-bold [text-shadow:0_0_6px_rgba(255,255,255,0.35)]">
        System Engineering Student
      </span>
      & Founder of
      <span class=" font-bold [text-shadow:0_0_6px_rgba(255,255,255,0.35)]">
        Capictive
      </span>
    </p>
    <div class="flex justify-center sm:justify-end items-center flex-wrap gap-2">
      <a href="#contacto" class="text-sm hover:underline">
        Connect with me
      </a>
      <a href="/Diogo CV.pdf" class="relative inline-block group" download>
        <button class="button-clean">CV</button>
        <span class="shadow-box"></span>
      </a>
    </div>
  </div>
</section>

<script>
  function initAvatar() {
    const avatarContainer = document.querySelector(".relative");
    const avatarColor = document.getElementById("avatar-color");
    
    if (avatarContainer && avatarColor) {
      avatarContainer.addEventListener("mouseenter", () => {
        avatarColor.classList.remove("opacity-0");
        avatarColor.classList.add("opacity-100");
      });
      avatarContainer.addEventListener("mouseleave", () => {
        avatarColor.classList.add("opacity-0");
        avatarColor.classList.remove("opacity-100");
      });
    }
  }
  
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAvatar);
  } else {
    initAvatar();
  }
</script>