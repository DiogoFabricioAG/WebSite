---
import Experiencebox from "../components/Experiencebox.astro";
import BoxLayout from "../layouts/BoxLayout.astro";
import { getAllExperiences } from "../utils/dataUtils";
const experiences = getAllExperiences();
---
<section id="experiencia" class="h-auto  px-4 py-8">
    <BoxLayout>
      <h2 class="text-3xl md:text-5xl font-extrabold mb-6 md:mb-10">Experiencia</h2>
      <div class="grid w-full grid-cols-1 sm:grid-cols-2 justify-center gap-5">
        {
          experiences.map((exp) => (
            <Experiencebox
              title={exp.title}
              company={exp.company}
              location={exp.location}
              durationDate={exp.durationDate}
              icon={exp.icon}
              companyUrl={exp.companyUrl || undefined}
              description={exp.description || undefined}
              points={exp.points}
              pointsColored={exp.pointsColored}
              metrics={exp.metrics}
              images={exp.images}
              techs={exp.techs || []}
              modalId={exp.id}
            />
          ))
        }

      </div>
    </BoxLayout>
    
  </section>